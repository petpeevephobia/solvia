# Solvia Production Caddyfile
# Automatic HTTPS with Let's Encrypt

# Redirect www to non-www
www.solvia.app {
    redir https://solvia.app{uri} permanent
}

# Main domain configuration
solvia.app {
    # Enable compression
    encode zstd gzip

    # Security headers
    header {
        # HSTS
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Prevent MIME type sniffing
        X-Content-Type-Options "nosniff"
        # Clickjacking protection
        X-Frame-Options "DENY"
        # XSS Protection
        X-XSS-Protection "1; mode=block"
        # Referrer Policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Content Security Policy
        Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://gzvtlxyfgfqkvoldmvtf.supabase.co wss://gzvtlxyfgfqkvoldmvtf.supabase.co"
        # Permissions Policy
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
    }

    # Dashboard static files with aggressive caching
    handle /static/* {
        root * /srv
        file_server {
            precompressed zstd br gzip
        }
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # Health check endpoint (no logging to reduce noise)
    handle /health {
        reverse_proxy app:8000
        header Cache-Control "no-cache, no-store, must-revalidate"
    }

    # API endpoints
    handle /api/* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}

            # Circuit breaker
            lb_policy round_robin
            lb_try_duration 30s
            lb_try_interval 5s

            # Health check
            health_uri /health
            health_interval 30s
            health_timeout 5s
            health_status 200
        }
    }

    # WebSocket support for real-time features
    handle /ws/* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up Connection {http.request.header.Connection}
            header_up Upgrade {http.request.header.Upgrade}
        }
    }

    # Dashboard Application at /spa
    handle /spa* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}

            # Timeouts for long-running requests
            transport http {
                read_timeout 30s
                write_timeout 30s
                dial_timeout 10s
            }
        }
    }

    # Dashboard authentication pages
    handle /login* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle /register* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle /logout* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Dashboard main pages
    handle /dashboard* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle /domain-selection* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle /property-selection* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle /setup* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle /ui* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle /test-* {
        reverse_proxy app:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Landing Page (root) - served by nginx container
    handle {
        reverse_proxy solvia-landing:80 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Logging configuration
    log {
        output stdout
        format json
        level INFO
    }

}

# Metrics endpoint (internal only)
:9090 {
    metrics /metrics
    basicauth /metrics {
        metrics $2a$14$Zkx19kUSVlvlz3NSZcRlN.cL2CvbR.VDj.1uLSg2XF3qsM3bDDzDm
    }
}

