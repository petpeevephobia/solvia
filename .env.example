# Solvia v2 - Environment Variables
# ==================================
# Copy to .env and fill in values

# Server
ENVIRONMENT=development
PORT=8080
BASE_URL=http://localhost:8080
POSTGRES_HOST_PORT=5433

# Database (PostgreSQL)
# DATABASE_URL=postgres://solvia:solvia_db_prod_Xk9Lm3Np7Qr_2025@postgres:5432/solvia?sslmode=disable
DATABASE_URL=postgres://solvia:solvia_secret@localhost:5432/solvia?sslmode=disable
POSTGRES_USER=solvia
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=solvia

# Google OAuth
GOOGLE_CLIENT_ID=978077754487-sf9ugurpp64likt60360pa1525uld4gu.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/callback

# OpenAI (AI Assistant)
GEMINI_API_KEY=gemini_api_key

# Firecrawl (On-Page SEO)
FIRECRAWL_API_KEY=firecrawl_api_key

# JWT
JWT_SECRET=jwt_secret

# Optional (used when app runs in Docker; empty is fine for local API-only dev)
SUPABASE_URL=
SUPABASE_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://solvia.app

# Frontend
VITE_API_URL=http://localhost:8080