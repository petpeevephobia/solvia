# Caddyfile for Solvia V2 (Go API + React SPA)
# Handles both development (localhost) and production domains

# Global options
{
	admin off
	servers {
		metrics
		timeouts {
			read_body   10s
			read_header 5s
			write       60s
			idle        2m
		}
	}
}

{$DOMAIN:localhost} {
	# Compression
	encode zstd gzip

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# Logging
	log {
		output stdout
		format json
		level INFO
	}

	# Health check endpoint
	handle /health {
		reverse_proxy app:8080 {
			health_uri /health
			health_interval 30s
			health_timeout 5s
		}
	}

	# API endpoints - Go backend
	handle /api/* {
		reverse_proxy app:8080 {
			lb_policy round_robin
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			transport http {
				read_timeout 120s
				write_timeout 120s
				dial_timeout 5s
			}
			fail_duration 10s
			max_fails 3
			unhealthy_status 5xx
		}

		# CORS headers for API
		header {
			Access-Control-Allow-Origin "{header.Origin}"
			Access-Control-Allow-Credentials "true"
			Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
			Access-Control-Allow-Headers "Authorization, Content-Type"
			Access-Control-Max-Age "3600"
		}
	}

	# Auth endpoints (OAuth flow - needs longer timeout)
	handle /auth/* {
		reverse_proxy app:8080 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			transport http {
				read_timeout 60s
				write_timeout 60s
			}
		}
	}

	# Static assets from React build (with caching)
	handle /assets/* {
		root * /srv/web/dist
		file_server
		header Cache-Control "public, max-age=31536000, immutable"
	}

	# Landing page (nginx container)
	handle {
		# Try React SPA first, fallback to landing page
		@notApi {
			not path /api/* /auth/* /health /assets/*
		}

		# For app routes like /dashboard, /audit, /settings - serve React SPA
		@appRoutes {
			path /login /dashboard /dashboard/* /audit /audit/* /settings /chat /gsc /domain-selection /auth/callback
		}
		handle @appRoutes {
			root * /srv/web/dist
			try_files {path} /index.html
			file_server
			header Cache-Control "no-cache, no-store, must-revalidate"
		}

		# Everything else goes to landing page
		handle {
			reverse_proxy solvia-landing:80 {
				header_up Host {host}
				header_up X-Real-IP {remote_host}
			}
		}
	}

	# Error handling
	handle_errors {
		@404 {
			expression {http.error.status_code} == 404
		}
		respond @404 "Page not found" 404

		@5xx {
			expression {http.error.status_code} >= 500
		}
		respond @5xx "Internal server error. Please try again later." 500
	}
}

# Redirect www to non-www
www.{$DOMAIN:localhost} {
	redir https://{$DOMAIN:localhost}{uri} permanent
}

# Health check endpoint for monitoring
:8081 {
	respond /health "OK" 200
}
