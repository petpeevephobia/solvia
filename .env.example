# Solvia v2 - Environment Variables
# ==================================
# Copy to .env and fill in values

# Server
ENVIRONMENT=development
PORT=8080
BASE_URL=http://localhost:8080

# Database (PostgreSQL)
# IMPORTANT: Use 'postgres' (service name) for Docker, 'localhost' for local PostgreSQL
# For Docker:   postgres://solvia:solvia_secret@postgres:5432/solvia?sslmode=disable
# For Local:    postgres://solvia:solvia_secret@localhost:5432/solvia?sslmode=disable
DATABASE_URL=postgres://solvia:solvia_secret@postgres:5432/solvia?sslmode=disable
POSTGRES_USER=solvia
POSTGRES_PASSWORD=solvia_secret
POSTGRES_DB=solvia

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/callback

# OpenAI (AI Assistant)
OPENAI_API_KEY=sk-your-openai-api-key

# Firecrawl (On-Page SEO)
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://solvia.app

# Frontend
VITE_API_URL=http://localhost:8080
