# Solvia V2 Environment Variables
# Copy this to .env and fill in your values

# Server
ENVIRONMENT=production
PORT=8080
DOMAIN=app.solvia.app

# Database (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-change-this

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://app.solvia.app/auth/callback

# AI Services (Gemini)
GEMINI_API_KEY=your-gemini-api-key

# Web Crawling (Firecrawl)
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Email (SMTP - Zoho)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=your-email@zoho.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@solvia.app

# Redis Cache (optional)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Frontend
VITE_API_URL=https://app.solvia.app/api/v1
